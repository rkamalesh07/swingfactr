# ============================================================
# SwingFactr Environment Configuration
# Copy this file: cp .env.example .env
# ============================================================

# Database (Docker default below — change for production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swingfactr

# CORS origins for FastAPI (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Next.js frontend: which API URL to call
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: The Odds API (free tier, 500 req/month)
# Only used for sanity-checking win prob against closing lines
# Sign up free at https://the-odds-api.com
ODDS_API_KEY=

# Production (fill in after Railway/Render deployment)
# DATABASE_URL=postgresql://user:pass@host:5432/swingfactr
